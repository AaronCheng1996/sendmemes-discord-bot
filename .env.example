# App
APP_NAME=sendmemes-discord-bot
APP_VERSION=1.0.0
# HTTP settings
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false
HTTP_PUBLIC_URL=http://localhost:8080
# Logger
LOG_LEVEL=debug

PG_POOL_MAX=2
# DB: set PG_URL directly, or use shared_env (POSTGRES_*) and config will build PG_URL
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sendmemes
POSTGRES_SSL_MODE=disable

# Admin API — required for /v1/admin/* endpoints and the UI dashboard
ADMIN_API_KEY=your_admin_api_key

# Discord
DISCORD_TOKEN=your_bot_token
DISCORD_APPLICATION_ID=your_application_id
DISCORD_GUILD_ID=your_guild_id
# Channel for scheduled periodic album sends
DISCORD_CHANNEL_ID=your_channel_id
# Channel for "new content discovered" sync notifications (empty = disabled)
DISCORD_NOTIFY_CHANNEL_ID=
# How often to push a random album to DISCORD_CHANNEL_ID (Go duration, e.g. 6h, 12h, 24h)
DISCORD_SEND_INTERVAL=5m
# How many of the most-recently-sent albums to skip when choosing the next scheduled album.
# When total albums ≤ this number, the history resets and all albums become eligible again.
DISCORD_SEND_HISTORY_SIZE=10
# Set to false to suppress per-request info logs (command received/completed, batch progress).
DISCORD_VERBOSE_LOG=true
# Default send_mode for albums created by pCloud sync and admin CreateAlbum calls
# that omit a mode. One of Order/Random/Single/Video/Custom.
ALBUM_DEFAULT_SEND_MODE=Random

# pCloud integration
# Auth priority: PCLOUD_ACCESS_TOKEN (below) > PCLOUD_USERNAME + PCLOUD_PASSWORD.
# When PCLOUD_ACCESS_TOKEN is set, username/password are ignored.
#
# PCLOUD_ACCESS_TOKEN can be either:
#   - a session token: browser "pcauth" cookie while logged in to my.pcloud.com,
#     or from https://api.pcloud.com/userinfo?getauth=1&logout=1&username=EMAIL&password=PASS
#     -> leave PCLOUD_TOKEN_TYPE=session
#   - an OAuth2 access token from a registered pCloud app (does not expire until
#     the app is revoked) -> set PCLOUD_TOKEN_TYPE=oauth
# The token is region-bound: match PCLOUD_API_ENDPOINT to the account's region
# (locationid 1 = api.pcloud.com, 2 = eapi.pcloud.com).
PCLOUD_ACCESS_TOKEN=
# "session" (sent as auth=) or "oauth" (sent as access_token=)
PCLOUD_TOKEN_TYPE=session
# Option B: username + password (used when PCLOUD_ACCESS_TOKEN is empty)
#           Note: pCloud may require an email verification code from a new/unknown IP.
PCLOUD_USERNAME=your_pcloud_email
PCLOUD_PASSWORD=your_pcloud_password
# Comma-separated list of pCloud folder IDs to sync (supports one or more folders)
# e.g. CLOUD_MAIN_FOLDER_ID=11111,22222
CLOUD_MAIN_FOLDER_ID=your_main_folder_id
# Use https://eapi.pcloud.com for EU-hosted pCloud accounts
PCLOUD_API_ENDPOINT=https://api.pcloud.com
# How often to sync images from pCloud (Go duration, e.g. 1h, 30m)
PCLOUD_SYNC_INTERVAL=1h
