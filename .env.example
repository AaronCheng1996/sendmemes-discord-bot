# App
SENDMEMES_APP_NAME=sendmemes-discord-bot
SENDMEMES_APP_VERSION=1.0.0
# HTTP settings
SENDMEMES_HTTP_PORT=8080
SENDMEMES_HTTP_USE_PREFORK_MODE=false
SENDMEMES_HTTP_PUBLIC_URL=http://localhost:8080
# Logger
SENDMEMES_LOG_LEVEL=debug

SENDMEMES_PG_POOL_MAX=2
# DB: set SENDMEMES_PG_URL directly, or use shared_env (SENDMEMES_POSTGRES_*) and config will build SENDMEMES_PG_URL
SENDMEMES_POSTGRES_USER=admin
SENDMEMES_POSTGRES_PASSWORD=your_password
SENDMEMES_POSTGRES_HOST=localhost
SENDMEMES_POSTGRES_PORT=5432
SENDMEMES_POSTGRES_DB=sendmemes
SENDMEMES_POSTGRES_SSL_MODE=disable

# Admin API — required for /v1/admin/* endpoints and the UI dashboard
SENDMEMES_ADMIN_API_KEY=your_admin_api_key

# Discord
SENDMEMES_DISCORD_TOKEN=your_bot_token
SENDMEMES_DISCORD_APPLICATION_ID=your_application_id
SENDMEMES_DISCORD_GUILD_ID=your_guild_id
# Channel for scheduled periodic album sends
SENDMEMES_DISCORD_CHANNEL_ID=your_channel_id
# Channel for "new content discovered" sync notifications (empty = disabled)
SENDMEMES_DISCORD_NOTIFY_CHANNEL_ID=
# How often to push a random album to SENDMEMES_DISCORD_CHANNEL_ID (Go duration, e.g. 6h, 12h, 24h)
SENDMEMES_DISCORD_SEND_INTERVAL=5m
# How many of the most-recently-sent albums to skip when choosing the next scheduled album.
# When total albums ≤ this number, the history resets and all albums become eligible again.
SENDMEMES_DISCORD_SEND_HISTORY_SIZE=10
# Set to false to suppress per-request info logs (command received/completed, batch progress).
SENDMEMES_DISCORD_VERBOSE_LOG=true
# Default send_mode for albums created by pCloud sync and admin CreateAlbum calls
# that omit a mode. One of Order/Random/Single/Video/Custom.
SENDMEMES_ALBUM_DEFAULT_SEND_MODE=Random

# pCloud integration
# Auth priority: SENDMEMES_PCLOUD_ACCESS_TOKEN (below) > SENDMEMES_PCLOUD_USERNAME + SENDMEMES_PCLOUD_PASSWORD.
# When SENDMEMES_PCLOUD_ACCESS_TOKEN is set, username/password are ignored.
#
# SENDMEMES_PCLOUD_ACCESS_TOKEN can be either:
#   - a session token: browser "pcauth" cookie while logged in to my.pcloud.com,
#     or from https://api.pcloud.com/userinfo?getauth=1&logout=1&username=EMAIL&password=PASS
#     -> leave SENDMEMES_PCLOUD_TOKEN_TYPE=session
#   - an OAuth2 access token from a registered pCloud app (does not expire until
#     the app is revoked) -> set SENDMEMES_PCLOUD_TOKEN_TYPE=oauth
# The token is region-bound: match SENDMEMES_PCLOUD_API_ENDPOINT to the account's region
# (locationid 1 = api.pcloud.com, 2 = eapi.pcloud.com).
SENDMEMES_PCLOUD_ACCESS_TOKEN=
# "session" (sent as auth=) or "oauth" (sent as access_token=)
SENDMEMES_PCLOUD_TOKEN_TYPE=session
# Option B: username + password (used when SENDMEMES_PCLOUD_ACCESS_TOKEN is empty)
#           Note: pCloud may require an email verification code from a new/unknown IP.
SENDMEMES_PCLOUD_USERNAME=your_pcloud_email
SENDMEMES_PCLOUD_PASSWORD=your_pcloud_password
# Comma-separated list of pCloud folder IDs to sync (supports one or more folders)
# e.g. SENDMEMES_CLOUD_MAIN_FOLDER_ID=11111,22222
SENDMEMES_CLOUD_MAIN_FOLDER_ID=your_main_folder_id
# Use https://eapi.pcloud.com for EU-hosted pCloud accounts
SENDMEMES_PCLOUD_API_ENDPOINT=https://api.pcloud.com
# How often to sync images from pCloud (Go duration, e.g. 1h, 30m)
SENDMEMES_PCLOUD_SYNC_INTERVAL=1h
